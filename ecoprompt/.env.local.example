AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1

# API protection — generate a random key (e.g. openssl rand -hex 32)
# Used by middleware to gate /api/* routes. Browser same-origin requests
# are allowed without this key; external callers must send x-api-key header.
API_SECRET_KEY=your-secret-api-key
